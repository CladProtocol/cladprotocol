# Local dev configuration. Copy to `.env` (gitignored) and fill in the blanks.
# The app runs on Node (Nitro `node-server`); src/api/env.ts reads process.env in
# both dev and prod. In dev, vite.config.ts loads this file via dotenv.

# Supabase Postgres connection string.
# RECOMMENDED — hosted Supabase project (supabase.com), used for BOTH dev and prod:
#   Dashboard → Project Settings → Database → Connection string → "Session pooler".
#   Copy the URI, replace [YOUR-PASSWORD], and append ?sslmode=require , e.g.:
#   postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#   (SSL is auto-enabled for non-local hosts; `prepare:false` keeps the pooler happy.)
# OPTIONAL — local Supabase CLI (`supabase start`, needs Docker):
#   postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# Seals the auth session cookie (>=32 chars). Generate: openssl rand -hex 32
SESSION_SECRET=

# Base RPC endpoint. MAINNET: an Alchemy/QuickNode Base endpoint, or the public
# node https://mainnet.base.org . (Testnet fallback: a Base Sepolia endpoint.)
BASE_RPC_URL=

# Treasury wallet key (0x-prefixed 32-byte hex). Signs USDC payouts + creator
# royalties + x402 settlement, and Arweave (Turbo) data items. On mainnet this is
# a PRODUCTION HOT WALLET holding real USDC + ETH — fund only a small operational
# float and rotate if exposed. Generate: cast wallet new
TREASURY_PRIVATE_KEY=

# Network selection: base = mainnet (real USDC), base-sepolia = testnet.
NETWORK=base

# Optional: enables the WalletConnect connector in the modal (cloud.reown.com).
# Injected (MetaMask) and Coinbase Wallet work without it.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: ArDrive Turbo upload endpoint for IRONCLAD/manifest Arweave anchoring.
# Defaults to https://upload.ardrive.io . Data items are signed with the treasury
# EVM key (TREASURY_PRIVATE_KEY); uploads < 100 KiB are free, so no Arweave wallet
# or AR tokens are needed. Leave unset for the default.
TURBO_UPLOAD_URL=

# Optional: IRONCLAD cron cadence for `npm run cron:watch` (default */10 * * * *).
IRONCLAD_CRON_SCHEDULE=

# Agent runner mode for NEW deploys + the fleet runner (src/runtime). `paper` =
# fully simulated, NO real funds move (default & recommended). `live` = bots may
# move real USDC — only enable once strategies are verified + the treasury is
# funded/capped. Existing instances keep the mode stored in their config.
RUNTIME_MODE=paper

# Optional: agent fleet runner cadence for `npm run agents:watch` (default */2 * * * *).
AGENT_CRON_SCHEDULE=

# Optional: PostgreSQL connection pool size per process (default: 10 local, 3 remote).
# Lower this if you hit "max clients reached" on the Supabase session pooler.
# Switch to the transaction pooler (port 6543) for higher concurrency.
PG_POOL_MAX=

# Note: no CDP / facilitator keys are required — the treasury self-settles x402
# payments (verify + submit) directly on Base, and self-signs Arweave data items.
